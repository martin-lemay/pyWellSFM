{
    "$schema": "http://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/martin-lemay/pyWellSFM/main/jsonSchemas/FSSimulationDataSchema.json",
    "title": "Input Simulation Data",
    "description": "Defines the input data to create FSM simulations.",
    "type": "object",
    "properties": {
        "format": {
            "description": "Defines the file content for verification purposes.",
            "const": "pyWellSFM.FSSimulationData"
        },
        "version": {
            "description": "Defines the file content version.",
            "const": "1.0"
        },
        "name": {
            "type": "string",
            "description": "Name of the simulation data."
        },
        "scenario": {
            "description": "Scenario data for the simulation.",
            "oneOf": [
                {
                    "description": "Inline scenario definition.",
                    "$ref": "https://raw.githubusercontent.com/martin-lemay/pyWellSFM/main/jsonSchemas/ScenarioSchema.json"
                },
                {
                    "type": "object",
                    "description": "Path to scenario JSON file.",
                    "properties": {
                        "url": {
                            "type": "string",
                            "description": "Relative or absolute path to the scenario JSON file."
                        }
                    },
                    "required": [
                        "url"
                    ],
                    "additionalProperties": false
                }
            ]
        },
        "realizations": {
            "type": "array",
            "description": "List of realization data.",
            "minItems": 1,
            "items": {
                "oneOf": [
                    {
                        "description": "Inline realization data definition.",
                        "$ref": "https://raw.githubusercontent.com/martin-lemay/pyWellSFM/main/jsonSchemas/RealizationDataSchema.json"
                    },
                    {
                        "type": "object",
                        "description": "Path to realization data JSON file.",
                        "properties": {
                            "url": {
                                "type": "string",
                                "description": "Relative or absolute path to the realization data JSON file."
                            }
                        },
                        "required": [
                            "url"
                        ],
                        "additionalProperties": false
                    }
                ]
            }
        },
        "use_depositional_environment_simulator": {
            "type": "boolean",
            "description": "Whether to use a depositional environment simulator. Default is false."
        },
        "deSimulator_weights": {
            "description": "Optional mapping from environment name to prior weight. If omitted, equal weights are used.",
            "type": "object",
            "$ref": "https://raw.githubusercontent.com/martin-lemay/pyWellSFM/main/jsonSchemas/DepositionalEnvironmentSimulatorSchema.json#/$defs/DESimulatorWeights"
        },
        "deSimulator_params": {
            "description": "Parameters for the depositional environment simulator.",
            "type": "object",
            "$ref": "https://raw.githubusercontent.com/martin-lemay/pyWellSFM/main/jsonSchemas/DepositionalEnvironmentSimulatorSchema.json#/$defs/DESimulatorParameters"
        },
        "params" : {
            "type": "object",
            "description": "Additional parameters for the simulation.",
            "properties": {
                "max_bathymetry_change_per_step": {
                    "type": "number",
                    "description": "Maximum allowed bathymetry change per step. Default is 0.5."
                },
                "dt_min": {
                    "type": "number",
                    "description": "Minimum time step size. Default is 1e-3."
                },
                "dt_max": {
                    "type": "number",
                    "description": "Maximum time step size. Default is 0.1."
                },
                "safety": {
                    "type": "number",
                    "description": "Safety factor for adaptive time stepping. Default is 0.9."
                },
                "max_steps": {
                    "type": "integer",
                    "description": "Maximum number of steps to simulate. Default is 1e9."
                }
            },
            "additionalProperties": false
        }
    },
    "required": [
        "format",
        "version",
        "name",
        "scenario",
        "realizations"
    ]
}