{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/martin-lemay/pyWellSFM/main/jsonSchemas/EnvironmentConditionsModelSchema.json",
  "title": "Input Environment Conditions Model Data",
  "description": "Defines the input data to create an EnvironmentConditionsModel (mapping condition name -> EnvironmentConditionModel).",
  "type": "object",
  "properties": {
    "format": {
      "description": "Defines the file content for verification purposes.",
      "const": "pyWellSFM.EnvironmentConditionsModelData"
    },
    "version": {
      "description": "Defines the file content version.",
      "const": "1.0"
    },
    "environmentConditions": {
      "description": "Mapping from environment condition name to its model definition.",
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "https://raw.githubusercontent.com/martin-lemay/pyWellSFM/main/jsonSchemas/EnvironmentConditionModelSchema.json"
      }
    }
  },
  "required": [
    "format",
    "version",
    "environmentConditions"
  ],
  "additionalProperties": false
}
