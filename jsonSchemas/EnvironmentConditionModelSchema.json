{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/martin-lemay/pyWellSFM/main/jsonSchemas/EnvironmentConditionModelSchema.json",
  "title": "Input Environment Condition Model Data",
  "description": "Environment condition model definition.",
  "type": "object",
  "properties": {
    "format": {
      "description": "Defines the file content for verification purposes.",
      "const": "pyWellSFM.EnvironmentConditionModelData"
    },
    "version": {
      "description": "Defines the file content version.",
      "const": "1.0"
    },
    "model": {
      "description": "Environment condition model definition. The model type is defined by the 'modelType' property.",
      "oneOf": [
        {
          "$ref": "#/$defs/SimpleModelDefinition"
        },
        {
          "$ref": "#/$defs/CombinationModel"
        }
      ]
    }
  },
  "required": [
    "format",
    "version",
    "model"
  ],
  "additionalProperties": false,
  "$defs": {
    "SimpleModelDefinition": {
      "type": "object",
      "oneOf": [
        {
          "$ref": "#/$defs/ConstantModel"
        },
        {
          "$ref": "#/$defs/UniformModel"
        },
        {
          "$ref": "#/$defs/TriangularModel"
        },
        {
          "$ref": "#/$defs/GaussianModel"
        },
        {
          "$ref": "#/$defs/CurveModel"
        }
      ]
    },
    "CurveInlineOrUrl": {
      "description": "Inline CurveSchema object or a {url: ...} reference.",
      "oneOf": [
        {
          "description": "Inline curve definition (CurveSchema).",
          "$ref": "https://raw.githubusercontent.com/martin-lemay/pyWellSFM/main/jsonSchemas/CurveSchema.json"
        },
        {
          "type": "object",
          "description": "Path to a curve file.",
          "properties": {
            "url": {
              "type": "string",
              "description": "Relative or absolute path to the curve file."
            }
          },
          "required": [
            "url"
          ],
          "additionalProperties": false
        }
      ]
    },
    "ConstantModel": {
      "type": "object",
      "properties": {
        "modelType": {
          "description": "Discriminator for the environment condition model type.",
          "const": "Constant"
        },
        "value": {
          "description": "Constant value of the environmental condition.",
          "type": "number"
        }
      },
      "required": [
        "modelType",
        "value"
      ],
      "additionalProperties": false
    },
    "UniformModel": {
      "type": "object",
      "properties": {
        "modelType": {
          "description": "Discriminator for the environment condition model type.",
          "const": "Uniform"
        },
        "minValue": {
          "description": "Minimum environmental condition value.",
          "type": "number"
        },
        "maxValue": {
          "description": "Maximum environmental condition value.",
          "type": "number"
        }
      },
      "required": [
        "modelType",
        "minValue",
        "maxValue"
      ],
      "additionalProperties": false
    },
    "TriangularModel": {
      "type": "object",
      "properties": {
        "modelType": {
          "description": "Discriminator for the environment condition model type.",
          "const": "Triangular"
        },
        "minValue": {
          "description": "Minimum environmental condition value.",
          "type": "number"
        },
        "modeValue": {
          "description": "Mode value of the triangular distribution.",
          "type": "number"
        },
        "maxValue": {
          "description": "Maximum environmental condition value.",
          "type": "number"
        }
      },
      "required": [
        "modelType",
        "minValue",
        "modeValue",
        "maxValue"
      ],
      "additionalProperties": false
    },
    "GaussianModel": {
      "type": "object",
      "properties": {
        "modelType": {
          "description": "Discriminator for the environment condition model type.",
          "const": "Gaussian"
        },
        "meanValue": {
          "description": "Mean value of the Gaussian distribution.",
          "type": "number"
        },
        "stdDev": {
          "description": "Standard deviation of the Gaussian distribution. If omitted, defaults to 0.2 * meanValue in the Python model.",
          "type": "number"
        },
        "minValue": {
          "description": "Optional lower bound clamp value.",
          "type": "number"
        },
        "maxValue": {
          "description": "Optional upper bound clamp value.",
          "type": "number"
        }
      },
      "required": [
        "modelType",
        "meanValue"
      ],
      "additionalProperties": false
    },
    "CurveModel": {
      "type": "object",
      "properties": {
        "modelType": {
          "description": "Discriminator for the environment condition model type.",
          "const": "Curve"
        },
        "curve": {
          "$ref": "#/$defs/CurveInlineOrUrl"
        }
      },
      "required": [
        "modelType",
        "curve"
      ],
      "additionalProperties": false
    },
    "CombinationModel": {
      "type": "object",
      "properties": {
        "modelType": {
          "description": "Discriminator for the environment condition model type.",
          "const": "Combination"
        },
        "models": {
          "description": "List of sub-models combined multiplicatively (coefficients) and/or additively (reference) in Python.",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/SimpleModelDefinition"
          }
        }
      },
      "required": [
        "modelType",
        "models"
      ],
      "additionalProperties": false
    }
  }
}
